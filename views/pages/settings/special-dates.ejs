<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold mb-0">Special Dates & Holidays</h3>
</div>

<div class="row">
  <div class="col-lg-3 mb-4">
    <div class="list-group shadow-sm">
      <a href="/settings" class="list-group-item list-group-item-action"><i class="bi bi-gear me-2"></i>General</a>
      <a href="/settings/hours" class="list-group-item list-group-item-action"><i class="bi bi-clock me-2"></i>Operating Hours</a>
      <a href="/settings/special-dates" class="list-group-item list-group-item-action active"><i class="bi bi-calendar-event me-2"></i>Special Dates</a>
      <a href="/settings/staff" class="list-group-item list-group-item-action"><i class="bi bi-people me-2"></i>Staff</a>
    </div>
  </div>

  <div class="col-lg-9">
    <!-- Add New -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white"><h6 class="fw-bold mb-0">Add Special Date</h6></div>
      <div class="card-body">
        <form action="/settings/special-dates" method="POST">
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label">Date <span class="text-danger">*</span></label>
              <input type="date" name="date" class="form-control" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Title <span class="text-danger">*</span></label>
              <input type="text" name="title" class="form-control" placeholder="e.g., Christmas" required>
            </div>
            <div class="col-md-2">
              <label class="form-label">Closed?</label>
              <div class="form-check form-switch mt-2">
                <input class="form-check-input" type="checkbox" name="is_closed" id="isClosed">
                <label class="form-check-label" for="isClosed">Closed</label>
              </div>
            </div>
            <div class="col-md-2">
              <label class="form-label">Open Time</label>
              <input type="time" name="special_opening_time" class="form-control">
            </div>
            <div class="col-md-2">
              <label class="form-label">Close Time</label>
              <input type="time" name="special_closing_time" class="form-control">
            </div>
            <div class="col-md-8">
              <label class="form-label">Notes</label>
              <input type="text" name="notes" class="form-control" placeholder="Optional notes...">
            </div>
            <div class="col-md-4 d-flex align-items-end">
              <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg me-1"></i>Add</button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Existing Special Dates -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white"><h6 class="fw-bold mb-0">Scheduled Special Dates</h6></div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Date</th>
                <th>Title</th>
                <th>Status</th>
                <th>Hours</th>
                <th>Notes</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (specialDates.length === 0) { %>
                <tr><td colspan="6" class="text-center text-muted py-4">No special dates configured</td></tr>
              <% } else { %>
                <% specialDates.forEach(function(sd) { %>
                  <tr>
                    <td class="fw-medium"><%= sd.date %></td>
                    <td><%= sd.title %></td>
                    <td>
                      <span class="badge bg-<%= sd.is_closed ? 'danger' : 'info' %>">
                        <%= sd.is_closed ? 'Closed' : 'Special Hours' %>
                      </span>
                    </td>
                    <td>
                      <% if (!sd.is_closed && sd.special_opening_time) { %>
                        <%= sd.special_opening_time %> - <%= sd.special_closing_time %>
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td><%= sd.notes || '-' %></td>
                    <td>
                      <form action="/settings/special-dates/<%= sd.id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Remove this special date?')">
                        <input type="hidden" name="_method" value="DELETE">
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
