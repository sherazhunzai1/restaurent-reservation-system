<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h3 class="fw-bold mb-1">Reservation <%= reservation.reservation_code %></h3>
    <span class="badge bg-<%= reservation.status === 'confirmed' ? 'primary' : reservation.status === 'pending' ? 'warning' : reservation.status === 'seated' ? 'info' : reservation.status === 'completed' ? 'success' : reservation.status === 'cancelled' ? 'danger' : 'secondary' %> fs-6">
      <%= reservation.status.replace('_', ' ') %>
    </span>
  </div>
  <div>
    <a href="/reservations/<%= reservation.id %>/edit" class="btn btn-outline-primary me-1"><i class="bi bi-pencil me-1"></i>Edit</a>
    <a href="/reservations" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <!-- Customer Info -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white"><h6 class="fw-bold mb-0"><i class="bi bi-person me-2"></i>Customer Information</h6></div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="text-muted small">Name</label>
            <p class="fw-medium mb-0"><%= reservation.customer_name %></p>
          </div>
          <div class="col-md-4">
            <label class="text-muted small">Phone</label>
            <p class="fw-medium mb-0"><%= reservation.customer_phone %></p>
          </div>
          <div class="col-md-4">
            <label class="text-muted small">Email</label>
            <p class="fw-medium mb-0"><%= reservation.customer_email || '-' %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Reservation Details -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white"><h6 class="fw-bold mb-0"><i class="bi bi-calendar-check me-2"></i>Reservation Details</h6></div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="text-muted small">Date</label>
            <p class="fw-medium mb-0"><%= moment(reservation.reservation_date).format('dddd, MMM D, YYYY') %></p>
          </div>
          <div class="col-md-3">
            <label class="text-muted small">Time</label>
            <p class="fw-medium mb-0"><%= reservation.reservation_time %><%= reservation.end_time ? ' - ' + reservation.end_time : '' %></p>
          </div>
          <div class="col-md-3">
            <label class="text-muted small">Party Size</label>
            <p class="fw-medium mb-0"><i class="bi bi-people me-1"></i><%= reservation.party_size %> guests</p>
          </div>
          <div class="col-md-3">
            <label class="text-muted small">Table</label>
            <p class="fw-medium mb-0"><%= reservation.table ? 'Table ' + reservation.table.table_number + (reservation.table.location ? ' (' + reservation.table.location.name + ')' : '') : 'Unassigned' %></p>
          </div>
          <div class="col-md-6">
            <label class="text-muted small">Source</label>
            <p class="mb-0"><span class="badge bg-light text-dark"><%= reservation.source %></span></p>
          </div>
          <div class="col-md-6">
            <label class="text-muted small">Created By</label>
            <p class="fw-medium mb-0"><%= reservation.creator ? reservation.creator.full_name : '-' %></p>
          </div>
        </div>
      </div>
    </div>

    <% if (reservation.special_requests || reservation.notes) { %>
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white"><h6 class="fw-bold mb-0"><i class="bi bi-chat-text me-2"></i>Notes</h6></div>
        <div class="card-body">
          <% if (reservation.special_requests) { %>
            <div class="mb-3">
              <label class="text-muted small">Special Requests</label>
              <p class="mb-0"><%= reservation.special_requests %></p>
            </div>
          <% } %>
          <% if (reservation.notes) { %>
            <div>
              <label class="text-muted small">Internal Notes</label>
              <p class="mb-0"><%= reservation.notes %></p>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>

  <div class="col-lg-4">
    <!-- Quick Actions -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white"><h6 class="fw-bold mb-0"><i class="bi bi-lightning me-2"></i>Quick Actions</h6></div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <% if (reservation.status === 'pending') { %>
            <form action="/reservations/<%= reservation.id %>/status" method="POST" class="d-inline">
              <input type="hidden" name="_method" value="PATCH">
              <input type="hidden" name="status" value="confirmed">
              <button class="btn btn-primary w-100"><i class="bi bi-check-circle me-1"></i>Confirm</button>
            </form>
          <% } %>
          <% if (reservation.status === 'confirmed') { %>
            <form action="/reservations/<%= reservation.id %>/status" method="POST" class="d-inline">
              <input type="hidden" name="_method" value="PATCH">
              <input type="hidden" name="status" value="seated">
              <button class="btn btn-info w-100 text-white"><i class="bi bi-box-arrow-in-down me-1"></i>Mark as Seated</button>
            </form>
          <% } %>
          <% if (reservation.status === 'seated') { %>
            <form action="/reservations/<%= reservation.id %>/status" method="POST" class="d-inline">
              <input type="hidden" name="_method" value="PATCH">
              <input type="hidden" name="status" value="completed">
              <button class="btn btn-success w-100"><i class="bi bi-check2-all me-1"></i>Mark as Completed</button>
            </form>
          <% } %>
          <% if (['pending', 'confirmed'].includes(reservation.status)) { %>
            <form action="/reservations/<%= reservation.id %>/status" method="POST" class="d-inline">
              <input type="hidden" name="_method" value="PATCH">
              <input type="hidden" name="status" value="cancelled">
              <button class="btn btn-outline-danger w-100"><i class="bi bi-x-circle me-1"></i>Cancel</button>
            </form>
            <form action="/reservations/<%= reservation.id %>/status" method="POST" class="d-inline">
              <input type="hidden" name="_method" value="PATCH">
              <input type="hidden" name="status" value="no_show">
              <button class="btn btn-outline-secondary w-100"><i class="bi bi-person-x me-1"></i>No Show</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Delete -->
    <div class="card border-0 shadow-sm">
      <div class="card-body">
        <form action="/reservations/<%= reservation.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this reservation?')">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn btn-outline-danger w-100"><i class="bi bi-trash me-1"></i>Delete Reservation</button>
        </form>
      </div>
    </div>
  </div>
</div>
