<!-- Page Header -->
<section class="relative min-h-[40vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-dark-200 via-dark-100 to-dark-50"></div>
  <div class="absolute inset-0 hero-glow opacity-50"></div>
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-warm-50 to-transparent"></div>
  <div class="relative z-10 text-center px-6 pt-20">
    <span class="inline-block px-4 py-1 border border-gold-200/30 rounded-full text-gold-200 text-[10px] font-semibold tracking-[3px] uppercase mb-4">Reservations</span>
    <h1 class="font-serif text-4xl lg:text-5xl font-bold text-white mb-2">Reserve a Table</h1>
    <p class="text-white/40 text-base">Book your dining experience with us</p>
  </div>
</section>

<section class="py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <!-- Main Form -->
      <div class="lg:col-span-7">
        <!-- Flash Messages -->
        <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
          <% error.forEach(function(msg) { %>
            <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm flex items-center gap-2">
              <i class="bi bi-exclamation-circle"></i><%= msg %>
            </div>
          <% }); %>
        <% } %>

        <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
          <div class="p-8 lg:p-10">
            <h4 class="font-serif text-2xl font-bold text-gray-900 mb-1">Reservation Details</h4>
            <p class="text-gray-400 text-sm mb-8">Fill in the form below to reserve your table.</p>

            <% if (!settings.allow_online_reservations) { %>
              <div class="p-5 bg-amber-50 border border-amber-200 rounded-xl text-amber-700 text-sm">
                <i class="bi bi-info-circle mr-2"></i>Online reservations are currently unavailable. Please call us at <strong><%= restaurant.phone %></strong> to make a reservation.
              </div>
            <% } else { %>
              <form action="/reserve" method="POST">
                <!-- Personal Info -->
                <div class="mb-8">
                  <div class="text-[11px] font-bold text-gold-200 uppercase tracking-[2px] pb-3 mb-5 border-b border-gold-200/15">Your Information</div>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name <span class="text-red-400">*</span></label>
                      <input type="text" name="customer_name" placeholder="John Smith" required
                        class="w-full px-4 py-3 border-2 border-gray-100 rounded-xl text-sm text-gray-800 bg-gray-50/50 placeholder:text-gray-300 focus:border-gold-200 focus:bg-white focus:ring-2 focus:ring-gold-200/10 transition-all outline-none">
                    </div>
                    <div>
                      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number <span class="text-red-400">*</span></label>
                      <input type="tel" name="customer_phone" placeholder="+1 (555) 123-4567" required
                        class="w-full px-4 py-3 border-2 border-gray-100 rounded-xl text-sm text-gray-800 bg-gray-50/50 placeholder:text-gray-300 focus:border-gold-200 focus:bg-white focus:ring-2 focus:ring-gold-200/10 transition-all outline-none">
                    </div>
                    <div class="md:col-span-2">
                      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
                      <input type="email" name="customer_email" placeholder="john@example.com"
                        class="w-full px-4 py-3 border-2 border-gray-100 rounded-xl text-sm text-gray-800 bg-gray-50/50 placeholder:text-gray-300 focus:border-gold-200 focus:bg-white focus:ring-2 focus:ring-gold-200/10 transition-all outline-none">
                    </div>
                  </div>
                </div>

                <!-- Reservation Details -->
                <div class="mb-8">
                  <div class="text-[11px] font-bold text-gold-200 uppercase tracking-[2px] pb-3 mb-5 border-b border-gold-200/15">Reservation Details</div>
                  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                    <div>
                      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Party Size <span class="text-red-400">*</span></label>
                      <select name="party_size" id="partySize" required
                        class="w-full px-4 py-3 border-2 border-gray-100 rounded-xl text-sm text-gray-800 bg-gray-50/50 focus:border-gold-200 focus:bg-white focus:ring-2 focus:ring-gold-200/10 transition-all outline-none appearance-none cursor-pointer">
                        <% for (let i = 1; i <= settings.max_party_size; i++) { %>
                          <option value="<%= i %>" <%= i === 2 ? 'selected' : '' %>><%= i %> <%= i === 1 ? 'Guest' : 'Guests' %></option>
                        <% } %>
                      </select>
                    </div>
                    <div>
                      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Date <span class="text-red-400">*</span></label>
                      <input type="date" name="reservation_date" id="reservationDate" required
                        class="w-full px-4 py-3 border-2 border-gray-100 rounded-xl text-sm text-gray-800 bg-gray-50/50 focus:border-gold-200 focus:bg-white focus:ring-2 focus:ring-gold-200/10 transition-all outline-none">
                    </div>
                    <div>
                      <label class="block text-sm font-semibold text-gray-700 mb-1.5">Time <span class="text-red-400">*</span></label>
                      <input type="time" name="reservation_time" id="reservationTime" required
                        class="w-full px-4 py-3 border-2 border-gray-100 rounded-xl text-sm text-gray-800 bg-gray-50/50 focus:border-gold-200 focus:bg-white focus:ring-2 focus:ring-gold-200/10 transition-all outline-none">
                    </div>
                  </div>
                </div>

                <!-- Table Selection -->
                <div id="tableSelectionSection" class="mb-8 hidden">
                  <div class="text-[11px] font-bold text-gold-200 uppercase tracking-[2px] pb-3 mb-5 border-b border-gold-200/15">Select Your Table</div>
                  <div id="tableLoadingMsg" class="hidden text-center text-gray-400 py-6">
                    <svg class="animate-spin h-5 w-5 text-gold-200 mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                    Finding available tables...
                  </div>
                  <div id="noTablesMsg" class="hidden p-4 bg-amber-50 border border-amber-200 rounded-xl text-amber-700 text-sm">
                    <i class="bi bi-exclamation-triangle mr-2"></i>No tables available for the selected date, time, and party size. Try adjusting your selection.
                  </div>
                  <div id="tableCards" class="grid grid-cols-2 md:grid-cols-3 gap-3"></div>
                  <input type="hidden" name="table_id" id="selectedTableId" value="">
                </div>

                <!-- Special Requests -->
                <div class="mb-8">
                  <label class="block text-sm font-semibold text-gray-700 mb-1.5">Special Requests</label>
                  <textarea name="special_requests" rows="3" placeholder="Dietary restrictions, allergies, celebrations, seating preferences..."
                    class="w-full px-4 py-3 border-2 border-gray-100 rounded-xl text-sm text-gray-800 bg-gray-50/50 placeholder:text-gray-300 focus:border-gold-200 focus:bg-white focus:ring-2 focus:ring-gold-200/10 transition-all outline-none resize-none"></textarea>
                </div>

                <!-- Submit -->
                <button type="submit" class="w-full py-4 bg-gold-200 text-white text-sm font-semibold uppercase tracking-widest rounded-full hover:bg-gold-300 hover:shadow-[0_10px_30px_rgba(200,169,126,0.3)] hover:-translate-y-0.5 transition-all duration-300">
                  <i class="bi bi-calendar-check mr-2"></i>Confirm Reservation
                </button>
              </form>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-5 space-y-6">
        <!-- Operating Hours -->
        <div class="bg-white rounded-2xl shadow-md border border-gray-100 overflow-hidden">
          <div class="bg-gradient-to-br from-dark-200 via-dark-100 to-dark-50 px-6 py-4 flex items-center gap-3">
            <i class="bi bi-clock text-gold-200 text-lg"></i>
            <h6 class="text-white font-semibold text-sm">Operating Hours</h6>
          </div>
          <div class="p-5">
            <% hours.forEach(function(h) { %>
              <div class="flex justify-between items-center py-2.5 border-b border-gray-50 last:border-0">
                <span class="text-gray-700 text-sm font-medium"><%= h.day_name %></span>
                <% if (h.is_open) { %>
                  <span class="text-emerald-600 text-sm font-medium"><%= h.opening_time %> - <%= h.closing_time %></span>
                <% } else { %>
                  <span class="text-red-400 text-sm font-semibold">Closed</span>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>

        <!-- Good to Know -->
        <div class="bg-white rounded-2xl shadow-md border border-gray-100 overflow-hidden">
          <div class="bg-gradient-to-br from-dark-200 via-dark-100 to-dark-50 px-6 py-4 flex items-center gap-3">
            <i class="bi bi-info-circle text-gold-200 text-lg"></i>
            <h6 class="text-white font-semibold text-sm">Good to Know</h6>
          </div>
          <div class="p-5 space-y-3">
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 text-[10px] flex-shrink-0 mt-0.5"><i class="bi bi-check2"></i></div>
              <span class="text-gray-500 text-sm leading-relaxed">Reservations must be made at least <strong class="text-gray-700"><%= settings.min_advance_booking_hours %> hours</strong> in advance</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 text-[10px] flex-shrink-0 mt-0.5"><i class="bi bi-check2"></i></div>
              <span class="text-gray-500 text-sm leading-relaxed">Book up to <strong class="text-gray-700"><%= settings.max_advance_booking_days %> days</strong> ahead</span>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 text-[10px] flex-shrink-0 mt-0.5"><i class="bi bi-check2"></i></div>
              <span class="text-gray-500 text-sm leading-relaxed">Max party size: <strong class="text-gray-700"><%= settings.max_party_size %> guests</strong></span>
            </div>
            <% if (settings.cancellation_policy) { %>
              <div class="mt-3 pt-3 border-t border-gray-50">
                <p class="text-gray-400 text-xs"><strong class="text-gray-500">Cancellation Policy:</strong> <%= settings.cancellation_policy %></p>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Need Help -->
        <div class="bg-white rounded-2xl shadow-md border border-gray-100 overflow-hidden">
          <div class="bg-gradient-to-br from-dark-200 via-dark-100 to-dark-50 px-6 py-4 flex items-center gap-3">
            <i class="bi bi-telephone text-gold-200 text-lg"></i>
            <h6 class="text-white font-semibold text-sm">Need Help?</h6>
          </div>
          <div class="p-5">
            <p class="text-gray-400 text-sm mb-4">For large parties or special events, please contact us directly.</p>
            <% if (restaurant.phone) { %>
              <div class="flex items-center gap-3 mb-2">
                <i class="bi bi-telephone text-gold-200"></i>
                <strong class="text-gray-700 text-sm"><%= restaurant.phone %></strong>
              </div>
            <% } %>
            <% if (restaurant.email) { %>
              <div class="flex items-center gap-3">
                <i class="bi bi-envelope text-gold-200"></i>
                <span class="text-gray-600 text-sm"><%= restaurant.email %></span>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var dateInput = document.getElementById('reservationDate');
  var timeInput = document.getElementById('reservationTime');
  var partySize = document.getElementById('partySize');
  var tableSection = document.getElementById('tableSelectionSection');
  var tableCards = document.getElementById('tableCards');
  var loadingMsg = document.getElementById('tableLoadingMsg');
  var noTablesMsg = document.getElementById('noTablesMsg');
  var selectedTableInput = document.getElementById('selectedTableId');

  if (dateInput) {
    var today = new Date();
    var minDate = new Date(today);
    minDate.setHours(minDate.getHours() + <%= settings.min_advance_booking_hours %>);
    var maxDate = new Date(today);
    maxDate.setDate(maxDate.getDate() + <%= settings.max_advance_booking_days %>);

    dateInput.min = minDate.toISOString().split('T')[0];
    dateInput.max = maxDate.toISOString().split('T')[0];
    dateInput.value = minDate.toISOString().split('T')[0];
  }

  var fetchTimeout = null;

  function fetchAvailableTables() {
    var date = dateInput ? dateInput.value : '';
    var time = timeInput ? timeInput.value : '';
    var size = partySize ? partySize.value : '';

    if (!date || !time || !size) {
      tableSection.classList.add('hidden');
      return;
    }

    selectedTableInput.value = '';
    tableSection.classList.remove('hidden');
    loadingMsg.classList.remove('hidden');
    noTablesMsg.classList.add('hidden');
    tableCards.innerHTML = '';

    clearTimeout(fetchTimeout);
    fetchTimeout = setTimeout(function() {
      fetch('/api/available-tables?date=' + encodeURIComponent(date) + '&time=' + encodeURIComponent(time) + '&party_size=' + encodeURIComponent(size))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          loadingMsg.classList.add('hidden');

          if (!data.tables || data.tables.length === 0) {
            noTablesMsg.classList.remove('hidden');
            return;
          }

          var html = '';
          data.tables.forEach(function(t) {
            var icon = t.location_icon || 'geo-alt';
            var locName = t.location_name || '';
            html += '<div class="table-card-wrapper">' +
              '<div class="table-option group cursor-pointer border-2 border-gray-100 rounded-xl p-4 text-center hover:border-gold-200 hover:shadow-md transition-all duration-300" data-table-id="' + t.id + '">' +
                '<div class="w-12 h-12 rounded-full bg-gold-200/10 flex items-center justify-center text-gold-200 mx-auto mb-2 group-hover:bg-gold-200 group-hover:text-white transition-all duration-300">' +
                  '<i class="bi bi-' + icon + '"></i>' +
                '</div>' +
                '<h6 class="font-bold text-gray-800 text-sm mb-0.5">Table ' + t.table_number + '</h6>' +
                '<p class="text-gray-400 text-xs mb-1"><i class="bi bi-people mr-1"></i>' + t.capacity + ' seats</p>' +
                (locName ? '<span class="inline-block text-[10px] font-semibold text-gold-300 bg-gold-200/10 px-2 py-0.5 rounded-full"><i class="bi bi-' + icon + ' mr-1"></i>' + locName + '</span>' : '') +
              '</div>' +
            '</div>';
          });

          tableCards.innerHTML = html;

          document.querySelectorAll('.table-option').forEach(function(card) {
            card.addEventListener('click', function() {
              document.querySelectorAll('.table-option').forEach(function(c) {
                c.classList.remove('selected', 'border-gold-200', 'shadow-md', 'ring-2', 'ring-gold-200/20');
                c.classList.add('border-gray-100');
              });
              card.classList.add('selected', 'border-gold-200', 'shadow-md', 'ring-2', 'ring-gold-200/20');
              card.classList.remove('border-gray-100');
              selectedTableInput.value = card.getAttribute('data-table-id');
            });
          });
        })
        .catch(function() {
          loadingMsg.classList.add('hidden');
          noTablesMsg.classList.remove('hidden');
        });
    }, 300);
  }

  if (dateInput) dateInput.addEventListener('change', fetchAvailableTables);
  if (timeInput) timeInput.addEventListener('change', fetchAvailableTables);
  if (partySize) partySize.addEventListener('change', fetchAvailableTables);
});
</script>
