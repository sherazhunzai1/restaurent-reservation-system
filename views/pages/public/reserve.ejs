<!-- Reserve Header -->
<section class="page-header d-flex align-items-center">
  <div class="container text-center header-content">
    <div class="header-badge">Reservations</div>
    <h1 class="font-serif fw-bold text-white mb-2">Reserve a Table</h1>
    <p style="color: rgba(255,255,255,0.5);">Book your dining experience with us</p>
  </div>
</section>

<section class="reserve-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <!-- Flash Messages -->
        <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
          <% error.forEach(function(msg) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <i class="bi bi-exclamation-circle me-2"></i><%= msg %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% }); %>
        <% } %>

        <div class="reserve-card">
          <div class="card-body">
            <h4 class="font-serif fw-bold mb-1">Reservation Details</h4>
            <p class="text-muted mb-4" style="font-size:0.9rem;">Fill in the form below to reserve your table.</p>

            <% if (!settings.allow_online_reservations) { %>
              <div class="alert alert-warning">
                <i class="bi bi-info-circle me-2"></i>Online reservations are currently unavailable. Please call us at <strong><%= restaurant.phone %></strong> to make a reservation.
              </div>
            <% } else { %>
              <form action="/reserve" method="POST">
                <div class="row g-3">
                  <div class="col-12">
                    <div class="form-section-title">Your Information</div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input type="text" name="customer_name" class="form-control" placeholder="John Smith" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Phone Number <span class="text-danger">*</span></label>
                    <input type="tel" name="customer_phone" class="form-control" placeholder="+1 (555) 123-4567" required>
                  </div>
                  <div class="col-12">
                    <label class="form-label">Email</label>
                    <input type="email" name="customer_email" class="form-control" placeholder="john@example.com">
                  </div>

                  <div class="col-12 mt-4">
                    <div class="form-section-title">Reservation Details</div>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Party Size <span class="text-danger">*</span></label>
                    <select name="party_size" id="partySize" class="form-select" required>
                      <% for (let i = 1; i <= settings.max_party_size; i++) { %>
                        <option value="<%= i %>" <%= i === 2 ? 'selected' : '' %>><%= i %> <%= i === 1 ? 'Guest' : 'Guests' %></option>
                      <% } %>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Date <span class="text-danger">*</span></label>
                    <input type="date" name="reservation_date" class="form-control" id="reservationDate" required>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Time <span class="text-danger">*</span></label>
                    <input type="time" name="reservation_time" class="form-control" id="reservationTime" required>
                  </div>

                  <!-- Table Selection -->
                  <div class="col-12" id="tableSelectionSection" style="display: none;">
                    <div class="form-section-title mt-2">Select Your Table</div>
                    <div id="tableLoadingMsg" class="text-center text-muted py-3" style="display: none;">
                      <div class="spinner-border spinner-border-sm me-2" style="color: var(--primary);" role="status"></div>
                      Finding available tables...
                    </div>
                    <div id="noTablesMsg" class="alert alert-warning" style="display: none;">
                      <i class="bi bi-exclamation-triangle me-2"></i>No tables available for the selected date, time, and party size. Try adjusting your selection.
                    </div>
                    <div id="tableCards" class="row g-3"></div>
                    <input type="hidden" name="table_id" id="selectedTableId" value="">
                  </div>

                  <div class="col-12">
                    <label class="form-label">Special Requests</label>
                    <textarea name="special_requests" class="form-control" rows="3" placeholder="Dietary restrictions, allergies, celebrations, seating preferences..."></textarea>
                  </div>

                  <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-submit-reservation btn-lg w-100">
                      <i class="bi bi-calendar-check me-2"></i>Confirm Reservation
                    </button>
                  </div>
                </div>
              </form>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Sidebar Info -->
      <div class="col-lg-4 offset-lg-1 mt-4 mt-lg-0">
        <div class="sidebar-card mb-4">
          <div class="card-header-custom">
            <i class="bi bi-clock"></i>
            <h6>Operating Hours</h6>
          </div>
          <div class="card-body">
            <% hours.forEach(function(h) { %>
              <div class="sidebar-hours-row">
                <small class="fw-semibold" style="color: var(--text-dark);"><%= h.day_name %></small>
                <% if (h.is_open) { %>
                  <small style="color: #2d8a56; font-weight: 500;"><%= h.opening_time %> - <%= h.closing_time %></small>
                <% } else { %>
                  <small style="color: var(--accent); font-weight: 600;">Closed</small>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>

        <div class="sidebar-card mb-4">
          <div class="card-header-custom">
            <i class="bi bi-info-circle"></i>
            <h6>Good to Know</h6>
          </div>
          <div class="card-body">
            <div class="info-list-item">
              <div class="icon-check"><i class="bi bi-check2"></i></div>
              <span>Reservations must be made at least <strong><%= settings.min_advance_booking_hours %> hours</strong> in advance</span>
            </div>
            <div class="info-list-item">
              <div class="icon-check"><i class="bi bi-check2"></i></div>
              <span>Book up to <strong><%= settings.max_advance_booking_days %> days</strong> ahead</span>
            </div>
            <div class="info-list-item">
              <div class="icon-check"><i class="bi bi-check2"></i></div>
              <span>Max party size: <strong><%= settings.max_party_size %> guests</strong></span>
            </div>
            <% if (settings.cancellation_policy) { %>
              <div class="mt-3 pt-3" style="border-top: 1px solid rgba(0,0,0,0.06);">
                <small style="color: var(--text-light);"><strong>Cancellation Policy:</strong> <%= settings.cancellation_policy %></small>
              </div>
            <% } %>
          </div>
        </div>

        <div class="sidebar-card">
          <div class="card-header-custom">
            <i class="bi bi-telephone"></i>
            <h6>Need Help?</h6>
          </div>
          <div class="card-body">
            <p style="color: var(--text-body); font-size: 0.9rem; margin-bottom: 1rem;">For large parties or special events, please contact us directly.</p>
            <% if (restaurant.phone) { %>
              <div class="footer-contact-item mb-2" style="color: var(--text-dark);">
                <i class="bi bi-telephone" style="color: var(--primary);"></i>
                <strong><%= restaurant.phone %></strong>
              </div>
            <% } %>
            <% if (restaurant.email) { %>
              <div class="footer-contact-item" style="color: var(--text-dark);">
                <i class="bi bi-envelope" style="color: var(--primary);"></i>
                <span><%= restaurant.email %></span>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const dateInput = document.getElementById('reservationDate');
  const timeInput = document.getElementById('reservationTime');
  const partySize = document.getElementById('partySize');
  const tableSection = document.getElementById('tableSelectionSection');
  const tableCards = document.getElementById('tableCards');
  const loadingMsg = document.getElementById('tableLoadingMsg');
  const noTablesMsg = document.getElementById('noTablesMsg');
  const selectedTableInput = document.getElementById('selectedTableId');

  if (dateInput) {
    const today = new Date();
    const minDate = new Date(today);
    minDate.setHours(minDate.getHours() + <%= settings.min_advance_booking_hours %>);
    const maxDate = new Date(today);
    maxDate.setDate(maxDate.getDate() + <%= settings.max_advance_booking_days %>);

    dateInput.min = minDate.toISOString().split('T')[0];
    dateInput.max = maxDate.toISOString().split('T')[0];
    dateInput.value = minDate.toISOString().split('T')[0];
  }

  let fetchTimeout = null;

  function fetchAvailableTables() {
    const date = dateInput ? dateInput.value : '';
    const time = timeInput ? timeInput.value : '';
    const size = partySize ? partySize.value : '';

    if (!date || !time || !size) {
      tableSection.style.display = 'none';
      return;
    }

    // Clear previous selection
    selectedTableInput.value = '';
    tableSection.style.display = '';
    loadingMsg.style.display = '';
    noTablesMsg.style.display = 'none';
    tableCards.innerHTML = '';

    clearTimeout(fetchTimeout);
    fetchTimeout = setTimeout(function() {
      fetch('/api/available-tables?date=' + encodeURIComponent(date) + '&time=' + encodeURIComponent(time) + '&party_size=' + encodeURIComponent(size))
        .then(function(r) { return r.json(); })
        .then(function(data) {
          loadingMsg.style.display = 'none';

          if (!data.tables || data.tables.length === 0) {
            noTablesMsg.style.display = '';
            return;
          }

          var html = '';
          data.tables.forEach(function(t) {
            var icon = t.location_icon || 'geo-alt';
            var locName = t.location_name || '';
            html += '<div class="col-md-4 col-sm-6">' +
              '<div class="card table-option h-100" data-table-id="' + t.id + '">' +
                '<div class="card-body text-center py-3">' +
                  '<div class="table-icon">' +
                    '<i class="bi bi-' + icon + '"></i>' +
                  '</div>' +
                  '<h6 class="fw-bold mb-1" style="font-size:0.95rem;">Table ' + t.table_number + '</h6>' +
                  '<p class="text-muted small mb-1"><i class="bi bi-people me-1"></i>' + t.capacity + ' seats</p>' +
                  (locName ? '<span class="badge" style="background:rgba(200,169,126,0.1);color:var(--primary-dark);font-weight:600;"><i class="bi bi-' + icon + ' me-1"></i>' + locName + '</span>' : '') +
                '</div>' +
              '</div>' +
            '</div>';
          });

          tableCards.innerHTML = html;

          // Add click handlers
          document.querySelectorAll('.table-option').forEach(function(card) {
            card.addEventListener('click', function() {
              document.querySelectorAll('.table-option').forEach(function(c) {
                c.classList.remove('selected');
                c.style.borderColor = '';
              });
              card.classList.add('selected');
              selectedTableInput.value = card.getAttribute('data-table-id');
            });
          });
        })
        .catch(function() {
          loadingMsg.style.display = 'none';
          noTablesMsg.style.display = '';
        });
    }, 300);
  }

  if (dateInput) dateInput.addEventListener('change', fetchAvailableTables);
  if (timeInput) timeInput.addEventListener('change', fetchAvailableTables);
  if (partySize) partySize.addEventListener('change', fetchAvailableTables);
});
</script>
