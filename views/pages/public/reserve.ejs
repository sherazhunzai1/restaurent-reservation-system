<!-- Reserve Header -->
<section class="page-header d-flex align-items-center">
  <div class="container text-center">
    <h1 class="font-serif fw-bold text-white mb-2">Reserve a Table</h1>
    <p class="text-white-50">Book your dining experience with us</p>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <!-- Flash Messages -->
        <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
          <% error.forEach(function(msg) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <i class="bi bi-exclamation-circle me-2"></i><%= msg %>
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% }); %>
        <% } %>

        <div class="card border-0 shadow-sm">
          <div class="card-body p-4 p-lg-5">
            <h4 class="font-serif fw-bold mb-4">Reservation Details</h4>

            <% if (!settings.allow_online_reservations) { %>
              <div class="alert alert-warning">
                <i class="bi bi-info-circle me-2"></i>Online reservations are currently unavailable. Please call us at <strong><%= restaurant.phone %></strong> to make a reservation.
              </div>
            <% } else { %>
              <form action="/reserve" method="POST">
                <div class="row g-3">
                  <div class="col-12">
                    <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">Your Information</h6>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input type="text" name="customer_name" class="form-control" placeholder="John Smith" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Phone Number <span class="text-danger">*</span></label>
                    <input type="tel" name="customer_phone" class="form-control" placeholder="+1 (555) 123-4567" required>
                  </div>
                  <div class="col-12">
                    <label class="form-label">Email</label>
                    <input type="email" name="customer_email" class="form-control" placeholder="john@example.com">
                  </div>

                  <div class="col-12 mt-4">
                    <h6 class="fw-bold text-primary border-bottom pb-2 mb-3">Reservation Details</h6>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Party Size <span class="text-danger">*</span></label>
                    <select name="party_size" class="form-select" required>
                      <% for (let i = 1; i <= settings.max_party_size; i++) { %>
                        <option value="<%= i %>" <%= i === 2 ? 'selected' : '' %>><%= i %> <%= i === 1 ? 'Guest' : 'Guests' %></option>
                      <% } %>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Date <span class="text-danger">*</span></label>
                    <input type="date" name="reservation_date" class="form-control" id="reservationDate" required>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label">Time <span class="text-danger">*</span></label>
                    <input type="time" name="reservation_time" class="form-control" required>
                  </div>

                  <div class="col-12">
                    <label class="form-label">Special Requests</label>
                    <textarea name="special_requests" class="form-control" rows="3" placeholder="Dietary restrictions, allergies, celebrations, seating preferences..."></textarea>
                  </div>

                  <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg w-100">
                      <i class="bi bi-calendar-check me-2"></i>Confirm Reservation
                    </button>
                  </div>
                </div>
              </form>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Sidebar Info -->
      <div class="col-lg-4 offset-lg-1">
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-clock me-2"></i>Operating Hours</h5>
            <% hours.forEach(function(h) { %>
              <div class="d-flex justify-content-between py-2 <%= h.day_of_week < 6 ? 'border-bottom' : '' %>">
                <small class="fw-medium"><%= h.day_name %></small>
                <% if (h.is_open) { %>
                  <small class="text-success"><%= h.opening_time %> - <%= h.closing_time %></small>
                <% } else { %>
                  <small class="text-danger">Closed</small>
                <% } %>
              </div>
            <% }); %>
          </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Good to Know</h5>
            <ul class="list-unstyled text-muted mb-0">
              <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Reservations must be made at least <strong><%= settings.min_advance_booking_hours %> hours</strong> in advance</li>
              <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Book up to <strong><%= settings.max_advance_booking_days %> days</strong> ahead</li>
              <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Max party size: <strong><%= settings.max_party_size %> guests</strong></li>
              <% if (settings.cancellation_policy) { %>
                <li class="mt-3"><small class="text-muted"><strong>Cancellation Policy:</strong> <%= settings.cancellation_policy %></small></li>
              <% } %>
            </ul>
          </div>
        </div>

        <div class="card border-0 shadow-sm">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-telephone me-2"></i>Need Help?</h5>
            <p class="text-muted mb-2">For large parties or special events, please contact us directly.</p>
            <% if (restaurant.phone) { %>
              <p class="mb-1"><i class="bi bi-telephone me-2 text-primary"></i><strong><%= restaurant.phone %></strong></p>
            <% } %>
            <% if (restaurant.email) { %>
              <p class="mb-0"><i class="bi bi-envelope me-2 text-primary"></i><%= restaurant.email %></p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const dateInput = document.getElementById('reservationDate');
  if (dateInput) {
    const today = new Date();
    const minDate = new Date(today);
    minDate.setHours(minDate.getHours() + <%= settings.min_advance_booking_hours %>);
    const maxDate = new Date(today);
    maxDate.setDate(maxDate.getDate() + <%= settings.max_advance_booking_days %>);

    dateInput.min = minDate.toISOString().split('T')[0];
    dateInput.max = maxDate.toISOString().split('T')[0];
    dateInput.value = minDate.toISOString().split('T')[0];
  }
});
</script>
