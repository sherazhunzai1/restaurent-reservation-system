<!-- Restaurant Header Bar -->
<div class="bg-gradient-to-r from-emerald-700 to-emerald-600 pt-24 pb-8">
  <div class="max-w-2xl mx-auto px-6 text-center">
    <h1 class="font-serif text-3xl font-bold text-white mb-1"><%= restaurant.name %></h1>
    <% if (restaurant.address) { %>
      <p class="text-emerald-100/70 text-sm"><%= restaurant.address %></p>
    <% } %>
  </div>
</div>

<!-- Flash Messages -->
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
  <div class="max-w-2xl mx-auto px-6 mt-4">
    <% error.forEach(function(msg) { %>
      <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm flex items-center gap-2 mb-2">
        <i class="bi bi-exclamation-circle"></i><%= msg %>
      </div>
    <% }); %>
  </div>
<% } %>

<% if (!settings.allow_online_reservations) { %>
  <div class="max-w-2xl mx-auto px-6 py-16">
    <div class="p-6 bg-amber-50 border border-amber-200 rounded-xl text-amber-700 text-center">
      <i class="bi bi-info-circle text-2xl mb-2 block"></i>
      <p class="font-semibold mb-1">Online reservations are currently unavailable</p>
      <p class="text-sm">Please call us at <strong><%= restaurant.phone %></strong> to make a reservation.</p>
    </div>
  </div>
<% } else { %>

<form action="/reserve" method="POST" id="reserveForm">
  <div class="max-w-2xl mx-auto px-6 py-8">

    <!-- Step 1: Guests & Date -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Guests</label>
        <div class="relative">
          <select name="party_size" id="partySize"
            class="w-full px-4 py-3.5 bg-white border-2 border-gray-200 rounded-xl text-sm font-medium text-gray-800 appearance-none cursor-pointer focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/10 transition-all outline-none">
            <% for (let i = 1; i <= settings.max_party_size; i++) { %>
              <option value="<%= i %>" <%= i === 2 ? 'selected' : '' %>><%= i %> <%= i === 1 ? 'Guest' : 'Guests' %></option>
            <% } %>
          </select>
          <div class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-gray-400">
            <i class="bi bi-chevron-down text-sm"></i>
          </div>
        </div>
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-2">Date</label>
        <div class="relative">
          <select name="reservation_date" id="reservationDate" required
            class="w-full px-4 py-3.5 bg-white border-2 border-gray-200 rounded-xl text-sm font-medium text-gray-800 appearance-none cursor-pointer focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/10 transition-all outline-none">
          </select>
          <div class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-gray-400">
            <i class="bi bi-chevron-down text-sm"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- Step 2: Time Slots -->
    <div id="timeSection">
      <h3 class="text-lg font-bold text-gray-900 mb-4">Select a time</h3>
      <div id="timeSlotsContainer">
        <div class="text-center py-8 text-gray-400 text-sm">
          <i class="bi bi-clock text-2xl block mb-2 text-gray-300"></i>
          Select a date to see available times
        </div>
      </div>
      <input type="hidden" name="reservation_time" id="selectedTime" value="">
    </div>

    <!-- Step 3: Location -->
    <div id="locationSection" class="mt-8 hidden">
      <h3 class="text-lg font-bold text-gray-900 mb-4">Location</h3>
      <div class="bg-white border-2 border-gray-200 rounded-xl overflow-hidden">
        <% locations.forEach(function(loc, idx) { %>
          <label class="flex items-center px-5 py-4 cursor-pointer hover:bg-gray-50 transition-colors <%= idx < locations.length - 1 ? 'border-b border-gray-100' : '' %>">
            <input type="radio" name="location_id" value="<%= loc.id %>" class="location-radio w-5 h-5 text-emerald-600 border-gray-300 focus:ring-emerald-500 cursor-pointer accent-emerald-600">
            <span class="ml-4 flex items-center gap-2">
              <i class="bi bi-<%= loc.icon || 'geo-alt' %> text-gray-400"></i>
              <span class="text-sm font-medium text-gray-800"><%= loc.name %></span>
            </span>
          </label>
        <% }); %>
      </div>
    </div>

    <!-- Step 4: Personal Info (shown after location) -->
    <div id="personalInfoSection" class="mt-8 hidden">
      <h3 class="text-lg font-bold text-gray-900 mb-4">Your details</h3>
      <div class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name <span class="text-red-400">*</span></label>
            <input type="text" name="customer_name" placeholder="John Smith" required
              class="w-full px-4 py-3.5 bg-white border-2 border-gray-200 rounded-xl text-sm text-gray-800 placeholder:text-gray-300 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/10 transition-all outline-none">
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone <span class="text-red-400">*</span></label>
            <input type="tel" name="customer_phone" placeholder="+1 (555) 123-4567" required
              class="w-full px-4 py-3.5 bg-white border-2 border-gray-200 rounded-xl text-sm text-gray-800 placeholder:text-gray-300 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/10 transition-all outline-none">
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email</label>
          <input type="email" name="customer_email" placeholder="john@example.com"
            class="w-full px-4 py-3.5 bg-white border-2 border-gray-200 rounded-xl text-sm text-gray-800 placeholder:text-gray-300 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/10 transition-all outline-none">
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700 mb-1.5">Special Requests</label>
          <textarea name="special_requests" rows="3" placeholder="Dietary restrictions, allergies, celebrations..."
            class="w-full px-4 py-3.5 bg-white border-2 border-gray-200 rounded-xl text-sm text-gray-800 placeholder:text-gray-300 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/10 transition-all outline-none resize-none"></textarea>
        </div>
      </div>
    </div>

    <!-- Terms -->
    <div id="termsSection" class="mt-8 hidden">
      <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
        <h4 class="text-sm font-bold text-gray-700 mb-2"><%= restaurant.name %> Terms & Conditions</h4>
        <p class="text-xs text-gray-400 leading-relaxed">
          By clicking "Continue" you agree to our reservation terms. Please arrive within 15 minutes of your reservation time.
          Late arrivals may result in your table being released. For cancellations, please notify us at least 2 hours in advance.
          <% if (settings.cancellation_policy) { %> <%= settings.cancellation_policy %><% } %>
        </p>
      </div>
    </div>

    <!-- Continue Button -->
    <div class="mt-8" id="submitSection" style="display:none;">
      <button type="submit" class="w-full py-4 bg-emerald-600 text-white text-sm font-bold uppercase tracking-widest rounded-xl hover:bg-emerald-700 hover:shadow-[0_10px_30px_rgba(16,185,129,0.25)] transition-all duration-300">
        Continue
      </button>
    </div>

  </div>
</form>

<% } %>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var dateInput = document.getElementById('reservationDate');
  var partySize = document.getElementById('partySize');
  var timeSlotsContainer = document.getElementById('timeSlotsContainer');
  var selectedTimeInput = document.getElementById('selectedTime');
  var locationSection = document.getElementById('locationSection');
  var personalInfoSection = document.getElementById('personalInfoSection');
  var termsSection = document.getElementById('termsSection');
  var submitSection = document.getElementById('submitSection');

  // Operating hours data from server
  var hoursData = <%- JSON.stringify(hours.map(function(h) { return { day_of_week: h.day_of_week, day_name: h.day_name, is_open: h.is_open, opening_time: h.opening_time, closing_time: h.closing_time }; })) %>;

  var dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  var monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

  function isOpenDay(dayOfWeek) {
    for (var i = 0; i < hoursData.length; i++) {
      if (hoursData[i].day_of_week === dayOfWeek) return hoursData[i].is_open;
    }
    return false;
  }

  function formatDateLabel(d) {
    var dn = dayNames[d.getDay()];
    var dd = (d.getDate() < 10 ? '0' : '') + d.getDate();
    var mm = monthNames[d.getMonth()];
    return dn + ', ' + dd + ' ' + mm;
  }

  function toDateValue(d) {
    var y = d.getFullYear();
    var m = (d.getMonth() + 1 < 10 ? '0' : '') + (d.getMonth() + 1);
    var dd = (d.getDate() < 10 ? '0' : '') + d.getDate();
    return y + '-' + m + '-' + dd;
  }

  // Populate date dropdown
  if (dateInput) {
    var today = new Date();
    today.setHours(0, 0, 0, 0);
    var minDate = new Date(today);
    minDate.setHours(minDate.getHours() + <%= settings.min_advance_booking_hours %>);
    var maxDays = <%= settings.max_advance_booking_days %>;

    var todayStr = toDateValue(today);
    var todayEntry = null;
    var futureEntries = [];

    for (var d = 0; d <= maxDays; d++) {
      var dt = new Date(today);
      dt.setDate(dt.getDate() + d);
      if (dt < minDate && d > 0) continue;
      if (!isOpenDay(dt.getDay())) continue;

      var val = toDateValue(dt);
      var label = formatDateLabel(dt);
      if (val === todayStr) {
        todayEntry = { value: val, label: label };
      } else {
        futureEntries.push({ value: val, label: label });
      }
    }

    var html = '';
    if (todayEntry) {
      html += '<optgroup label="Today">';
      html += '<option value="' + todayEntry.value + '">' + todayEntry.label + '</option>';
      html += '</optgroup>';
    }
    if (futureEntries.length > 0) {
      html += '<optgroup label="Available for booking">';
      futureEntries.forEach(function(e) {
        html += '<option value="' + e.value + '">' + e.label + '</option>';
      });
      html += '</optgroup>';
    }

    dateInput.innerHTML = html;

    // Generate slots on load
    generateTimeSlots();
  }

  function generateTimeSlots() {
    var dateVal = dateInput.value;
    if (!dateVal) return;

    // Reset selection
    selectedTimeInput.value = '';
    locationSection.classList.add('hidden');
    personalInfoSection.classList.add('hidden');
    termsSection.classList.add('hidden');
    submitSection.style.display = 'none';

    // Get day of week for selected date
    var selectedDate = new Date(dateVal + 'T12:00:00');
    var dayOfWeek = selectedDate.getDay(); // 0=Sun, 1=Mon, ...

    // Find matching hours
    var dayHours = null;
    for (var i = 0; i < hoursData.length; i++) {
      if (hoursData[i].day_of_week === dayOfWeek) {
        dayHours = hoursData[i];
        break;
      }
    }

    if (!dayHours || !dayHours.is_open) {
      timeSlotsContainer.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm">' +
        '<i class="bi bi-calendar-x text-2xl block mb-2 text-gray-300"></i>' +
        'We are closed on ' + (dayHours ? dayHours.day_name : 'this day') + '</div>';
      return;
    }

    // Parse times
    var openParts = dayHours.opening_time.split(':');
    var closeParts = dayHours.closing_time.split(':');
    var openMinutes = parseInt(openParts[0]) * 60 + parseInt(openParts[1]);
    var closeMinutes = parseInt(closeParts[0]) * 60 + parseInt(closeParts[1]);

    // Generate 15-min interval slots
    var slots = [];
    for (var m = openMinutes; m < closeMinutes; m += 15) {
      var hours24 = Math.floor(m / 60);
      var mins = m % 60;
      var h12 = hours24 % 12 || 12;
      var ampm = hours24 < 12 ? 'AM' : 'PM';
      var display = h12 + ':' + (mins < 10 ? '0' : '') + mins + ' ' + ampm;
      var value = (hours24 < 10 ? '0' : '') + hours24 + ':' + (mins < 10 ? '0' : '') + mins;
      slots.push({ display: display, value: value });
    }

    if (slots.length === 0) {
      timeSlotsContainer.innerHTML = '<div class="text-center py-8 text-gray-400 text-sm">No available time slots</div>';
      return;
    }

    var html = '<div class="grid grid-cols-4 gap-2">';
    slots.forEach(function(slot) {
      html += '<button type="button" class="time-slot-btn py-3 px-2 text-sm font-medium rounded-lg border-2 border-gray-200 text-gray-700 bg-white hover:border-emerald-500 hover:text-emerald-700 transition-all" data-time="' + slot.value + '">' + slot.display + '</button>';
    });
    html += '</div>';
    timeSlotsContainer.innerHTML = html;

    // Attach click handlers
    document.querySelectorAll('.time-slot-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.time-slot-btn').forEach(function(b) {
          b.classList.remove('border-emerald-500', 'bg-emerald-50', 'text-emerald-700');
          b.classList.add('border-gray-200', 'text-gray-700', 'bg-white');
        });
        btn.classList.remove('border-gray-200', 'text-gray-700', 'bg-white');
        btn.classList.add('border-emerald-500', 'bg-emerald-50', 'text-emerald-700');
        selectedTimeInput.value = btn.getAttribute('data-time');

        // Show next sections
        locationSection.classList.remove('hidden');
        personalInfoSection.classList.remove('hidden');
        termsSection.classList.remove('hidden');
        submitSection.style.display = '';

        // Smooth scroll to location
        locationSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  // Regenerate slots when date changes
  if (dateInput) dateInput.addEventListener('change', generateTimeSlots);
  if (partySize) partySize.addEventListener('change', function() {
    // Reset flow when party size changes
    selectedTimeInput.value = '';
    locationSection.classList.add('hidden');
    personalInfoSection.classList.add('hidden');
    termsSection.classList.add('hidden');
    submitSection.style.display = 'none';
    // Re-highlight nothing
    document.querySelectorAll('.time-slot-btn').forEach(function(b) {
      b.classList.remove('border-emerald-500', 'bg-emerald-50', 'text-emerald-700');
      b.classList.add('border-gray-200', 'text-gray-700', 'bg-white');
    });
  });

  // Validation before submit
  var form = document.getElementById('reserveForm');
  if (form) {
    form.addEventListener('submit', function(e) {
      if (!selectedTimeInput.value) {
        e.preventDefault();
        alert('Please select a time slot.');
        return;
      }
    });
  }
});
</script>
