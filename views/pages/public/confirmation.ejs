<!-- Page Header -->
<section class="relative min-h-[40vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-dark-200 via-dark-100 to-dark-50"></div>
  <div class="absolute inset-0 hero-glow opacity-50"></div>
  <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-warm-50 to-transparent"></div>
  <div class="relative z-10 text-center px-6 pt-20">
    <span class="inline-block px-4 py-1 border border-gold-200/30 rounded-full text-gold-200 text-[10px] font-semibold tracking-[3px] uppercase mb-4">Confirmed</span>
    <h1 class="font-serif text-4xl lg:text-5xl font-bold text-white mb-2">Reservation Confirmed</h1>
    <p class="text-white/40 text-base">Thank you for choosing <%= restaurant.name %></p>
  </div>
</section>

<section class="py-16 lg:py-20">
  <div class="max-w-2xl mx-auto px-6">
    <!-- Success Icon -->
    <div class="text-center mb-8">
      <div class="w-24 h-24 rounded-full bg-gradient-to-br from-emerald-500 to-emerald-700 flex items-center justify-center text-white text-4xl mx-auto mb-5 shadow-[0_15px_40px_rgba(16,185,129,0.25)]">
        <i class="bi bi-check-lg"></i>
      </div>
      <h3 class="font-serif text-3xl font-bold text-gray-900 mb-2">Your Table is Reserved!</h3>
      <p class="text-gray-400">We've received your reservation request. Here are your details:</p>
    </div>

    <!-- Details Card -->
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden mb-8">
      <div class="p-8">
        <!-- Reservation Code -->
        <div class="text-center mb-8">
          <span class="inline-flex items-center gap-2 px-6 py-3 bg-gold-200/10 border border-gold-200/20 rounded-full text-gold-300 font-bold text-base tracking-wider">
            <i class="bi bi-ticket-perforated"></i><%= reservation.reservation_code %>
          </span>
        </div>

        <!-- Details Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
          <div class="py-4 px-4 border-b border-gray-50">
            <div class="text-[10px] font-bold uppercase tracking-wider text-gray-300 mb-0.5">Name</div>
            <div class="font-semibold text-gray-800"><%= reservation.customer_name %></div>
          </div>
          <div class="py-4 px-4 border-b border-gray-50">
            <div class="text-[10px] font-bold uppercase tracking-wider text-gray-300 mb-0.5">Phone</div>
            <div class="font-semibold text-gray-800"><%= reservation.customer_phone %></div>
          </div>
          <% if (reservation.customer_email) { %>
            <div class="py-4 px-4 border-b border-gray-50 md:col-span-2">
              <div class="text-[10px] font-bold uppercase tracking-wider text-gray-300 mb-0.5">Email</div>
              <div class="font-semibold text-gray-800"><%= reservation.customer_email %></div>
            </div>
          <% } %>
          <div class="py-4 px-4 border-b border-gray-50 md:border-b-0">
            <div class="text-[10px] font-bold uppercase tracking-wider text-gray-300 mb-0.5">Date</div>
            <div class="font-semibold text-gray-800"><%= reservation.reservation_date %></div>
          </div>
          <div class="py-4 px-4 border-b border-gray-50 md:border-b-0">
            <div class="text-[10px] font-bold uppercase tracking-wider text-gray-300 mb-0.5">Time</div>
            <div class="font-semibold text-gray-800"><%= reservation.reservation_time %></div>
          </div>
          <div class="py-4 px-4">
            <div class="text-[10px] font-bold uppercase tracking-wider text-gray-300 mb-0.5">Party Size</div>
            <div class="font-semibold text-gray-800"><%= reservation.party_size %> <%= reservation.party_size === 1 ? 'Guest' : 'Guests' %></div>
          </div>
          <% if (reservation.special_requests) { %>
            <div class="py-4 px-4 md:col-span-2 border-t border-gray-50">
              <div class="text-[10px] font-bold uppercase tracking-wider text-gray-300 mb-0.5">Special Requests</div>
              <div class="font-semibold text-gray-800"><%= reservation.special_requests %></div>
            </div>
          <% } %>
        </div>

        <!-- Status -->
        <div class="mt-6 pt-6 border-t border-gray-100 text-center">
          <% if (reservation.status === 'confirmed') { %>
            <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-50 border border-emerald-200 rounded-full text-emerald-700 font-semibold text-sm">
              <i class="bi bi-check-circle-fill"></i> Confirmed
            </span>
            <p class="text-gray-400 text-sm mt-2">Your reservation is confirmed. See you soon!</p>
          <% } else { %>
            <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-amber-50 border border-amber-200 rounded-full text-amber-700 font-semibold text-sm">
              <i class="bi bi-hourglass-split"></i> Pending Confirmation
            </span>
            <p class="text-gray-400 text-sm mt-2">Our team will confirm your reservation shortly.</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="text-center">
      <p class="text-gray-400 text-sm mb-5">
        Please save your reservation code: <strong class="text-gold-300"><%= reservation.reservation_code %></strong>
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="w-full sm:w-auto px-8 py-3 border border-gold-200 text-gold-200 text-sm font-semibold uppercase tracking-wider rounded-full hover:bg-gold-200 hover:text-white transition-all duration-300">
          <i class="bi bi-house mr-1"></i>Back to Home
        </a>
        <a href="/reserve" class="w-full sm:w-auto px-8 py-3 bg-gold-200 text-white text-sm font-semibold uppercase tracking-wider rounded-full hover:bg-gold-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
          <i class="bi bi-plus-lg mr-1"></i>Make Another
        </a>
      </div>
    </div>
  </div>
</section>
