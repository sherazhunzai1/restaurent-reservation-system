<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= restaurant.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            gold: { 50: '#faf5eb', 100: '#e8d5b7', 200: '#c8a97e', 300: '#b08d5e', 400: '#956f3e' },
            dark: { 50: '#0f3460', 100: '#16213e', 200: '#1a1a2e', 300: '#0f1526' },
            warm: { 50: '#faf8f5', 100: '#f5f0ea' }
          },
          fontFamily: {
            serif: ['"Cormorant Garamond"', 'serif'],
            sans: ['"Plus Jakarta Sans"', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/public.css" rel="stylesheet">
</head>
<body class="font-sans text-gray-800 bg-warm-50 antialiased">

  <!-- Navbar -->
  <nav id="mainNav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between" id="navInner">
      <a href="/" class="font-serif text-2xl font-bold text-white tracking-wide hover:opacity-80 transition"><%= restaurant.name %></a>
      <button id="mobileToggle" class="lg:hidden text-white text-2xl focus:outline-none">
        <i class="bi bi-list"></i>
      </button>
      <div id="navLinks" class="hidden lg:flex items-center gap-1">
        <a href="/#about" class="nav-link-item px-4 py-2 text-sm font-medium text-white/70 hover:text-gold-200 uppercase tracking-wider transition">About</a>
        <a href="/#hours" class="nav-link-item px-4 py-2 text-sm font-medium text-white/70 hover:text-gold-200 uppercase tracking-wider transition">Hours</a>
        <a href="/#contact" class="nav-link-item px-4 py-2 text-sm font-medium text-white/70 hover:text-gold-200 uppercase tracking-wider transition">Contact</a>
        <a href="/reserve" class="ml-4 px-7 py-2.5 border border-gold-200 text-gold-200 text-sm font-semibold uppercase tracking-wider rounded-full hover:bg-gold-200 hover:text-white transition-all duration-300">Reserve</a>
      </div>
    </div>
    <!-- Mobile Menu -->
    <div id="mobileMenu" class="hidden lg:hidden bg-dark-200/95 backdrop-blur-xl border-t border-white/5">
      <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col gap-2">
        <a href="/#about" class="py-2 text-sm text-white/70 hover:text-gold-200 uppercase tracking-wider">About</a>
        <a href="/#hours" class="py-2 text-sm text-white/70 hover:text-gold-200 uppercase tracking-wider">Hours</a>
        <a href="/#contact" class="py-2 text-sm text-white/70 hover:text-gold-200 uppercase tracking-wider">Contact</a>
        <a href="/reserve" class="mt-2 text-center px-6 py-2.5 border border-gold-200 text-gold-200 text-sm font-semibold uppercase tracking-wider rounded-full hover:bg-gold-200 hover:text-white transition-all">Reserve</a>
      </div>
    </div>
  </nav>

  <%- body %>

  <!-- Footer -->
  <footer class="bg-dark-300 pt-20 pb-8">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
        <div class="lg:col-span-1">
          <span class="font-serif text-2xl font-bold text-white block mb-3"><%= restaurant.name %></span>
          <p class="text-white/40 text-sm leading-relaxed max-w-xs"><%= restaurant.tagline || 'Experience the finest dining' %></p>
        </div>
        <div>
          <h6 class="text-white text-xs font-bold uppercase tracking-[3px] mb-5">Navigate</h6>
          <div class="flex flex-col gap-2.5">
            <a href="/" class="text-white/40 text-sm hover:text-gold-200 transition">Home</a>
            <a href="/#about" class="text-white/40 text-sm hover:text-gold-200 transition">About</a>
            <a href="/#hours" class="text-white/40 text-sm hover:text-gold-200 transition">Hours</a>
            <a href="/reserve" class="text-white/40 text-sm hover:text-gold-200 transition">Reserve</a>
          </div>
        </div>
        <div>
          <h6 class="text-white text-xs font-bold uppercase tracking-[3px] mb-5">More</h6>
          <div class="flex flex-col gap-2.5">
            <a href="/#contact" class="text-white/40 text-sm hover:text-gold-200 transition">Contact</a>
            <a href="/admin/auth/login" class="text-white/40 text-sm hover:text-gold-200 transition">Admin</a>
          </div>
        </div>
        <div>
          <h6 class="text-white text-xs font-bold uppercase tracking-[3px] mb-5">Contact</h6>
          <div class="flex flex-col gap-3">
            <% if (restaurant.address) { %>
              <div class="flex items-center gap-3 text-white/40 text-sm"><i class="bi bi-geo-alt text-gold-200"></i><span><%= restaurant.address %></span></div>
            <% } %>
            <% if (restaurant.phone) { %>
              <div class="flex items-center gap-3 text-white/40 text-sm"><i class="bi bi-telephone text-gold-200"></i><span><%= restaurant.phone %></span></div>
            <% } %>
            <% if (restaurant.email) { %>
              <div class="flex items-center gap-3 text-white/40 text-sm"><i class="bi bi-envelope text-gold-200"></i><span><%= restaurant.email %></span></div>
            <% } %>
          </div>
        </div>
      </div>
      <div class="border-t border-white/5 pt-6">
        <p class="text-center text-white/25 text-xs">&copy; <%= new Date().getFullYear() %> <%= restaurant.name %>. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    // Navbar scroll effect
    window.addEventListener('scroll', function() {
      const nav = document.getElementById('mainNav');
      const inner = document.getElementById('navInner');
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
        nav.style.background = 'rgba(26, 26, 46, 0.97)';
        nav.style.backdropFilter = 'blur(20px)';
        nav.style.boxShadow = '0 4px 30px rgba(0,0,0,0.2)';
        inner.classList.remove('py-5');
        inner.classList.add('py-3');
      } else {
        nav.classList.remove('scrolled');
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.boxShadow = 'none';
        inner.classList.remove('py-3');
        inner.classList.add('py-5');
      }
    });
    window.dispatchEvent(new Event('scroll'));

    // Mobile menu toggle
    document.getElementById('mobileToggle').addEventListener('click', function() {
      var menu = document.getElementById('mobileMenu');
      menu.classList.toggle('hidden');
    });
  </script>
</body>
</html>
